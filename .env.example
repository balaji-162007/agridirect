# ── Database (Production: MySQL, Development: SQLite)
DATABASE_URL=sqlite+aiosqlite:///backend/agridirect.db
# Example MySQL: mysql+aiomysql://user:password@host:3306/agridirect?charset=utf8mb4

# ── Security
SECRET_KEY=generate-a-long-random-string-here
ALLOWED_ORIGINS=http://localhost:5500,https://yourdomain.com

# ── Razorpay (Payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── OTP Provider (mock | twilio | msg91)
OTP_PROVIDER=mock

# Twilio Config (if using twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# MSG91 Config (if using msg91)
MSG91_API_KEY=
MSG91_SENDER_ID=AGRIDR
MSG91_TEMPLATE_ID=
