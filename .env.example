# ─────────────────────────────────────────────────────────────────
# AgriDirect – Environment Variables
# Copy this file to backend/.env for local development.
# On Render, set these under: Service → Environment → Add Variable
# ─────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────
# Render PostgreSQL: copy the "Internal Database URL" from your DB's dashboard
DATABASE_URL=postgresql://user:password@host:5432/agridirect

# Local SQLite fallback (dev only):
# DATABASE_URL=sqlite:///./agridirect.db

# ── Security ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-long-random-string-here

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# On Render: set to your Render static site URL or custom domain
ALLOWED_ORIGINS=http://localhost:5500,https://your-frontend.onrender.com

# ── Image URLs ───────────────────────────────────────────────────
# Set to your Render backend service URL so uploaded image paths are absolute
BASE_URL=https://your-backend.onrender.com

# ── Razorpay (Payments) ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── OTP Provider (mock | twilio | msg91) ─────────────────────────
OTP_PROVIDER=mock

# Twilio Config (if OTP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# MSG91 Config (if OTP_PROVIDER=msg91)
MSG91_API_KEY=
MSG91_SENDER_ID=AGRIDR
MSG91_TEMPLATE_ID=
